# Agent_Movie Settings - Configured dynamically via Ansible deployment template

[provider]
translate = "{{ translate_provider | mandatory }}"

[scanner]
media_paths = {{ media_paths | mandatory | to_json }}

[opensubtitles]
api_key = "{{ opensubtitles_api_key | mandatory }}"
username = "{{ opensubtitles_username | mandatory }}"
password = "{{ opensubtitles_password | mandatory }}"

[translate.common]
system_prompt = """你是专业的电影字幕翻译员。将英文字幕翻译为自然流畅的简体中文。
保持 [序号] 格式不变，只翻译文本内容。翻译要符合中文观影习惯，不要直译。"""
timeout = {{ translate_timeout | mandatory }}
batch_size = {{ translate_batch_size | mandatory }}
temperature = {{ translate_temperature | mandatory }}

[translate.gemini]
api_key = "{{ gemini_api_key | mandatory }}"
model = "{{ gemini_translate_model | mandatory }}"

[translate.openai]
api_key = "{{ openai_api_key | mandatory }}"
model = "{{ openai_translate_model | mandatory }}"

[translate.mistral]
api_key = "{{ mistral_api_key | mandatory }}"
model = "{{ mistral_translate_model | mandatory }}"

[translate.groq]
api_key = "{{ groq_api_key | mandatory }}"
model = "{{ groq_translate_model | mandatory }}"

[translate.nvidia]
api_key = "{{ nvidia_api_key | mandatory }}"
model = "{{ nvidia_translate_model | mandatory }}"

[web]
host = "{{ web_host | mandatory }}"
port = {{ web_port | mandatory }}
